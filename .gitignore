# =============================================================================
# .gitignore — Analytics Engineer Challenge (Air Côte d'Ivoire)
# Goal: only ship the deliverables to the recruiter. Anything that is
# regenerable, local, machine-specific, or sensitive stays out of git.
# =============================================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# ---------- Virtual envs ----------
venv/
.venv/
env/
ENV/
.venv-requirements-snapshot.txt

# ---------- Test / lint caches ----------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---------- Generated data (regenerated via scripts/run_all.py) ----------
data/enriched/*
!data/enriched/.gitkeep

# ---------- DuckDB / dbt artefacts (regenerated via `dbt build`) ----------
*.duckdb
*.duckdb.wal
*.duckdb.tmp
*.duckdb-shm
*.duckdb-wal
dbt/target/
dbt/dbt_packages/
dbt/dbt_internal_packages/
dbt/logs/
dbt/.user.yml
# Note: dbt/profiles.yml IS committed — DuckDB path only, no secrets.

# ---------- Notebooks ----------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------- IDE / OS ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------- Logs / temp ----------
*.log
*.tmp
*.bak

# ---------- Secrets ----------
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ---------- Superset local runtime (docker volumes, instance data) ----------
dashboard/superset/superset_home/
dashboard/superset/.docker/

# ---------- Recruiter-provided inputs (recruiter already has them) ----------
air_cote_divoire_starter_dataset.xlsx
analytics_engineer_challenge_brief.docx.pdf

# ---------- Unused / redundant placeholders ----------
notebooks/
dashboard/.gitkeep
dbt/.gitkeep
