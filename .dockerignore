# =============================================================================
# Exclude regenerable / local / sensitive content from the Docker build context.
# Mirrors .gitignore plus a few container-only exclusions.
# =============================================================================

# ---------- Git ----------
.git/
.gitignore

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# ---------- Virtual envs ----------
.venv/
venv/
env/
ENV/
.venv-requirements-snapshot.txt

# ---------- Test / lint caches ----------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---------- Regenerated artefacts ----------
data/enriched/*
!data/enriched/.gitkeep
dbt/target/
dbt/dbt_packages/
dbt/dbt_internal_packages/
dbt/logs/
dbt/.user.yml
*.duckdb
*.duckdb.wal
*.duckdb.tmp
*.duckdb-shm
*.duckdb-wal

# ---------- Notebooks ----------
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/

# ---------- IDE / OS ----------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---------- Logs / temp ----------
*.log
*.tmp
*.bak

# ---------- Secrets ----------
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# ---------- Superset runtime ----------
dashboard/superset/superset_home/
dashboard/superset/.docker/

# ---------- Heavyweight recruiter inputs (mounted at runtime if needed) ----------
air_cote_divoire_starter_dataset.xlsx
analytics_engineer_challenge_brief.docx.pdf

# ---------- Docs (not needed in the image) ----------
docs/screenshots/
